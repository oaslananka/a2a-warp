{
  "name": "@oaslananka/a2a-warp-core",
  "version": "2.0.0",
  "description": "Agent2Agent protocol TypeScript types, interfaces, constants, and validators.",
  "keywords": [
    "a2a",
    "agent2agent",
    "types",
    "protocol"
  ],
  "author": "oaslananka",
  "license": "Apache-2.0",
  "homepage": "https://oaslananka.github.io/a2a-warp/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaslananka/a2a-warp.git",
    "directory": "packages/core-types"
  },
  "bugs": {
    "url": "https://github.com/oaslananka/a2a-warp/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "node ../../scripts/build-tsc-package.mjs",
    "typecheck": "tsc -b",
    "test": "echo 'No runtime tests for core-types; tested through package consumers' && exit 0"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "6.0.3"
  },
  "type": "module",
  "engines": {
    "node": ">=22.22.1 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
