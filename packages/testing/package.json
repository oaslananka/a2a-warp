{
  "name": "@oaslananka/a2a-warp-testing",
  "version": "1.0.3",
  "description": "Testing fixtures, matchers, and local server helpers for A2A Warp.",
  "keywords": [
    "a2a",
    "agent2agent",
    "testing",
    "vitest",
    "typescript"
  ],
  "author": "oaslananka",
  "license": "Apache-2.0",
  "homepage": "https://oaslananka.github.io/a2a-warp/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaslananka/a2a-warp.git",
    "directory": "packages/testing"
  },
  "bugs": {
    "url": "https://github.com/oaslananka/a2a-warp/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "node ../../scripts/build-tsc-package.mjs",
    "typecheck": "tsc -b",
    "test": "vitest run"
  },
  "dependencies": {
    "@oaslananka/a2a-warp": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "type": "module",
  "engines": {
    "node": ">=22.22.1 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
