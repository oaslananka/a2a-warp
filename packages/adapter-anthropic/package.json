{
  "name": "@oaslananka/a2a-warp-adapter-anthropic",
  "version": "8.1.4",
  "description": "Anthropic Claude adapter for the Agent2Agent protocol.",
  "keywords": [
    "a2a",
    "agent2agent",
    "anthropic",
    "claude",
    "adapter"
  ],
  "author": "oaslananka",
  "license": "Apache-2.0",
  "homepage": "https://oaslananka.github.io/a2a-warp/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaslananka/a2a-warp.git",
    "directory": "packages/adapter-anthropic"
  },
  "bugs": {
    "url": "https://github.com/oaslananka/a2a-warp/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "node ../../scripts/build-tsc-package.mjs",
    "typecheck": "tsc -b",
    "test": "pnpm --dir ../.. run build && vitest run --root ../.. --config vitest.config.ts --project unit packages/adapter-anthropic/tests"
  },
  "dependencies": {
    "@oaslananka/a2a-warp": "workspace:^",
    "@oaslananka/a2a-warp-adapter-base": "workspace:^"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.39.0 || ^0.95.0 || ^0.96.0 || ^0.99.0 || ^0.100.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "6.0.3"
  },
  "type": "module",
  "engines": {
    "node": ">=22.22.1 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
