{
  "name": "@oaslananka/a2a-warp",
  "version": "1.19.0",
  "description": "Agent2Agent protocol runtime, client, auth, telemetry, storage, and middleware for TypeScript.",
  "keywords": [
    "a2a",
    "agent2agent",
    "ai-agents",
    "multi-agent",
    "typescript"
  ],
  "author": "oaslananka",
  "license": "Apache-2.0",
  "homepage": "https://oaslananka.github.io/a2a-warp/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaslananka/a2a-warp.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/oaslananka/a2a-warp/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "node ../../scripts/build-tsc-package.mjs",
    "typecheck": "tsc -b",
    "test": "vitest run --root ../.. --config vitest.config.ts --project unit packages/core/tests"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "eventsource": "^4.1.0",
    "express": "^5.2.1",
    "express-rate-limit": "8.5.2",
    "jose": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "typescript": "6.0.3"
  },
  "type": "module",
  "engines": {
    "node": ">=22.22.1 <25"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.1"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "import": "./dist/middleware/index.js",
      "default": "./dist/middleware/index.js"
    },
    "./telemetry": {
      "types": "./dist/telemetry/index.d.ts",
      "import": "./dist/telemetry/index.js",
      "default": "./dist/telemetry/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js",
      "default": "./dist/auth/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/public.d.ts",
      "import": "./dist/schemas/public.js",
      "default": "./dist/schemas/public.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "default": "./dist/client/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "default": "./dist/testing/index.js"
    },
    "./codex-bridge": {
      "types": "./dist/codex-bridge/index.d.ts",
      "import": "./dist/codex-bridge/index.js",
      "default": "./dist/codex-bridge/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
