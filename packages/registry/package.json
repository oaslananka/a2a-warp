{
  "name": "@oaslananka/a2a-warp-registry",
  "version": "1.0.0",
  "description": "Agent registry, discovery API, health polling, and storage backends for A2A Warp.",
  "keywords": [
    "a2a",
    "agent2agent",
    "registry",
    "discovery",
    "typescript"
  ],
  "author": "oaslananka",
  "license": "Apache-2.0",
  "homepage": "https://oaslananka.github.io/a2a-warp/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaslananka/a2a-warp.git",
    "directory": "packages/registry"
  },
  "bugs": {
    "url": "https://github.com/oaslananka/a2a-warp/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "node ../../scripts/build-tsc-package.mjs",
    "typecheck": "tsc -b",
    "test": "vitest run --root ../.. --config vitest.config.ts --project unit packages/registry/tests"
  },
  "dependencies": {
    "@oaslananka/a2a-warp": "workspace:^",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "typescript": "^6.0.3"
  },
  "type": "module",
  "engines": {
    "node": ">=22.22.1 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "a2a-warp-registry": "bin/a2a-warp-registry.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json",
    "bin"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
