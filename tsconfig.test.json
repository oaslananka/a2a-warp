{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@oaslananka/a2a-warp": ["./packages/core/src/index.ts"],
      "@oaslananka/a2a-warp-adapter-anthropic": ["./packages/adapter-anthropic/src/index.ts"],
      "@oaslananka/a2a-warp-adapter-base": ["./packages/adapter-base/src/index.ts"],
      "@oaslananka/a2a-warp-adapter-crewai": ["./packages/adapter-crewai/src/index.ts"],
      "@oaslananka/a2a-warp-adapter-google-adk": ["./packages/adapter-google-adk/src/index.ts"],
      "@oaslananka/a2a-warp-adapter-langchain": ["./packages/adapter-langchain/src/index.ts"],
      "@oaslananka/a2a-warp-adapter-llamaindex": ["./packages/adapter-llamaindex/src/index.ts"],
      "@oaslananka/a2a-warp-adapter-openai": ["./packages/adapter-openai/src/index.ts"],
      "@oaslananka/a2a-warp-adapters": ["./packages/adapters/src/index.ts"],
      "@oaslananka/a2a-warp-auth": ["./packages/auth/src/index.ts"],
      "@oaslananka/a2a-warp-bridge-mcp": ["./packages/bridge-mcp/src/index.ts"],
      "@oaslananka/a2a-warp-cli": ["./cli/src/index.ts"],
      "@oaslananka/a2a-warp-core": ["./packages/core-types/src/index.ts"],
      "@oaslananka/a2a-warp-registry": ["./packages/registry/src/index.ts"],
      "@oaslananka/a2a-warp-telemetry": ["./packages/telemetry/src/index.ts"],
      "@oaslananka/a2a-warp-transport-grpc": ["./packages/transport-grpc/src/index.ts"],
      "@oaslananka/a2a-warp-transport-ws": ["./packages/transport-ws/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/tests/**/*.ts",
    "cli/src/**/*.ts",
    "cli/tests/**/*.ts",
    "examples/*/src/**/*.ts",
    "examples/*/tests/**/*.ts",
    "tests/**/*.ts",
    "apps/registry-ui/tests/**/*.ts",
    "apps/registry-ui/playwright.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
