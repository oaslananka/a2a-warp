{
  "name": "@oaslananka/a2a-warp-cli",
  "version": "5.0.1",
  "description": "Command-line tools for validating, discovering, sending, monitoring, and testing A2A agents.",
  "keywords": [
    "a2a",
    "agent2agent",
    "cli",
    "typescript",
    "tooling"
  ],
  "author": "oaslananka",
  "license": "Apache-2.0",
  "homepage": "https://oaslananka.github.io/a2a-warp/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaslananka/a2a-warp.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/oaslananka/a2a-warp/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "bin": {
    "a2a-warp": "bin/a2a-warp.js"
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "node ../scripts/build-tsc-package.mjs",
    "start": "node dist/index.js",
    "test": "vitest run --root .. --project unit cli/tests",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@oaslananka/a2a-warp": "workspace:^",
    "@oaslananka/a2a-warp-registry": "workspace:^",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "typescript": "6.0.3"
  },
  "type": "module",
  "engines": {
    "node": ">=22.22.1 <25"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json",
    "bin"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
