{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "useUnknownInCatchVariables": true,
    "noPropertyAccessFromIndexSignature": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "composite": true,
    "paths": {
      "@oaslananka/a2a-warp": ["./packages/core/src/index.ts"],
      "@oaslananka/a2a-warp-adapters": ["./packages/adapters/src/index.ts"],
      "@oaslananka/a2a-warp-registry": ["./packages/registry/src/index.ts"],
      "@oaslananka/a2a-warp-cli": ["./cli/src/index.ts"],
      "@oaslananka/a2a-warp-transport-grpc": ["./packages/transport-grpc/src/index.ts"],
      "@oaslananka/a2a-warp-transport-ws": ["./packages/transport-ws/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
