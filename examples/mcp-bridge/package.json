  },
  "dependencies": {
    "@oaslananka/a2a-warp-mcp-bridge": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.22.1 <25",
    "pnpm": ">=11 <12"
  }
}
