{
  "name": "@oaslananka/a2a-warp-example-mcp-bridge",
  "version": "1.0.0",
  "private": true,
  "description": "MCP bridge mapping example for A2A Warp.",
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
