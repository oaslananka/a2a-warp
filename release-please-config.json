{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "separate-pull-requests": false,
  "plugins": [
    {
      "type": "node-workspace"
    },
    {
      "type": "linked-versions",
      "groupName": "A2A Warp packages",
      "components": [
        "@oaslananka/a2a-warp",
        "@oaslananka/a2a-warp-adapters",
        "@oaslananka/a2a-warp-registry",
        "@oaslananka/a2a-warp-cli",
        "create-a2a-warp",
        "@oaslananka/a2a-warp-bridge-mcp",
        "@oaslananka/a2a-warp-transport-ws",
        "@oaslananka/a2a-warp-transport-grpc",
        "@oaslananka/a2a-warp-schemas"
      ]
    }
  ],
  "packages": {
    "packages/core": {
      "package-name": "@oaslananka/a2a-warp",
      "component": "@oaslananka/a2a-warp",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/adapters": {
      "package-name": "@oaslananka/a2a-warp-adapters",
      "component": "@oaslananka/a2a-warp-adapters",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/registry": {
      "package-name": "@oaslananka/a2a-warp-registry",
      "component": "@oaslananka/a2a-warp-registry",
      "changelog-path": "CHANGELOG.md"
    },
    "cli": {
      "package-name": "@oaslananka/a2a-warp-cli",
      "component": "@oaslananka/a2a-warp-cli",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/create-a2a-agent": {
      "package-name": "create-a2a-warp",
      "component": "create-a2a-warp",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/bridge-mcp": {
      "package-name": "@oaslananka/a2a-warp-bridge-mcp",
      "component": "@oaslananka/a2a-warp-bridge-mcp",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/transport-ws": {
      "package-name": "@oaslananka/a2a-warp-transport-ws",
      "component": "@oaslananka/a2a-warp-transport-ws",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/transport-grpc": {
      "package-name": "@oaslananka/a2a-warp-transport-grpc",
      "component": "@oaslananka/a2a-warp-transport-grpc",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/schemas": {
      "package-name": "@oaslananka/a2a-warp-schemas",
      "component": "@oaslananka/a2a-warp-schemas",
      "changelog-path": "CHANGELOG.md"
    }
  }
}
